# Producer(scripts/ga_daily_report.py) 로컬 수동 실행용 환경변수.
#
# 사용법:
#   cp .env.example .env   # 값 채우기 (.env는 gitignore됨)
#   set -a && source .env && set +a
#   python scripts/ga_daily_report.py
#
# CI/cron은 이 파일을 쓰지 않는다. GitHub Actions Secret으로 주입된다
# (.github/workflows/daily-ga-report.yml 참조).
# 값은 코드/PR/커밋에 적지 않는다 (AGENTS.md §6).

# GA4 Data API OAuth (Google Cloud 콘솔에서 발급)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Discord 알림 webhook
DISCORD_WEBHOOK_URL=

# aggregation ingest API URL = `terraform -chdir=aggregation/infra output -raw api_endpoint`
AGGREGATION_INGEST_URL=
